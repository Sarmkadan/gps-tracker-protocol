// appsettings.example.json
{
  "GpsTrackerProtocol": {
    "DefaultProtocol": "GT06",
    "MaxDevices": 10000,
    "LocationHistoryLimit": 1000,
    "CacheExpirationMinutes": 60,
    "RateLimitPerMinute": 1000,
    "LoggingLevel": "Information",
    "ProtocolSettings": {
      "GT06Enabled": true,
      "GT06Timeout": 30,
      "GT06MaxFrameSize": 200,
      "H02Enabled": true,
      "H02Timeout": 30,
      "H02MaxFrameSize": 300,
      "TK103Enabled": true,
      "TK103Timeout": 30,
      "TK103MaxFrameSize": 100
    }
  }
}
